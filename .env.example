# ─────────────────────────────────────────────────────────────────
# KACTI LABS — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a GitHub — solo .env.example.
# ─────────────────────────────────────────────────────────────────

# Web3Forms Access Key — https://web3forms.com/ (gratis, sin backend)
# Obtén tu clave en: https://web3forms.com/#start
VITE_WEB3FORMS_KEY=your_access_key_here

# WhatsApp — número en formato internacional (sin + ni espacios)
VITE_WHATSAPP_NUMBER=51999999999

# Supabase — https://supabase.com
# Settings → API → Project URL  (sin trailing slash)
VITE_SUPABASE_URL=https://XXXXXXXXXX.supabase.co
# Settings → API → Project API keys → fila "anon public" (Publishable key)
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXX
